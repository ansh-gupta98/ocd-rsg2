# ──────────────────────────────────────────────────────────────────────────────
# OCD RAG Backend Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# Required: HuggingFace API token for LLM inference
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Optional: HuggingFace LLM model ID (defaults to Llama-3.1-8B-Instruct)
HF_LLM_REPO_ID=meta-llama/Llama-3.1-8B-Instruct

# Optional: HuggingFace embedding model (defaults to all-MiniLM-L6-v2)
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: Path to knowledge base directory (must contain .txt, .pdf, or .md files)
# Defaults to ./ocd_documentation
OCD_KNOWLEDGE_DIR=./ocd_documentation

# Optional: Path to vector store directory (FAISS index)
# Defaults to ./ocd_documentation_vector
# On Railway, this SHOULD point to /tmp or ephemeral storage (rebuilt on restart)
OCD_VECTOR_STORE_DIR=./ocd_documentation_vector

# Optional: Force rebuild of vector store on startup
# Set to 'true', 'yes', or '1' to rebuild
OCD_REBUILD_VECTOR=false
